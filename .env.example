# ── Application ────────────────────────────────────────────────
APP_ENV=local                    # local | staging | production
APP_NAME=questforge
API_V1_PREFIX=/api/v1
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000"]

# ── Database (Neon in prod, local Postgres in dev) ─────────────
DATABASE_URL=postgresql+asyncpg://questforge:questforge@db:5432/questforge
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# ── Redis (Upstash in prod, local in dev) ──────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Object storage (Cloudflare R2; S3-compatible by design) ────
OBJECT_STORAGE_ENDPOINT=https://<account>.r2.cloudflarestorage.com
OBJECT_STORAGE_BUCKET=questforge-assets
OBJECT_STORAGE_ACCESS_KEY=
OBJECT_STORAGE_SECRET_KEY=
OBJECT_STORAGE_REGION=auto

# ── AI service ─────────────────────────────────────────────────
AI_PROVIDER=echo                 # echo | anthropic
AI_MODEL=claude-sonnet-4-6
AI_API_KEY=
AI_DISPATCH=celery               # celery | inline
AI_CACHE_TTL_SECONDS=86400
AI_RATE_LIMIT_PER_MINUTE=20

# ── Commerce (Stripe) ──────────────────────────────────────────
PAYMENT_PROVIDER=fake            # fake | stripe
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Auth ───────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
MICROSOFT_OAUTH_CLIENT_ID=
MICROSOFT_OAUTH_CLIENT_SECRET=

# ── Frontend ───────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
